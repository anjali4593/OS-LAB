#include <stdio.h>

int main() {
    int n, m; // n = number of processes, m = number of resources
    int i, j, k;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    printf("Enter number of resources: ");
    scanf("%d", &m);

    int Allocation[n][m], Max[n][m], Need[n][m];
    int Available[m];

    // Input Allocation Matrix
    printf("Enter Allocation Matrix:\n");
    for (i = 0; i < n; i++) {
        for (j = 0; j < m; j++) {
            scanf("%d", &Allocation[i][j]);
        }
    }

    // Input Maximum Matrix
    printf("Enter Maximum Matrix:\n");
    for (i = 0; i < n; i++) {
        for (j = 0; j < m; j++) {
            scanf("%d", &Max[i][j]);
        }
    }

    // Input Available Resources
    printf("Enter Available Resources:\n");
    for (j = 0; j < m; j++) {
        scanf("%d", &Available[j]);
    }

    // Calculate Need Matrix
    printf("\nNeed Matrix:\n");
    for (i = 0; i < n; i++) {
        for (j = 0; j < m; j++) {
            Need[i][j] = Max[i][j] - Allocation[i][j];
            printf("%d ", Need[i][j]);
        }
        printf("\n");
    }

    // --- Safe State Check ---
    int Finish[n], SafeSequence[n], Work[m];
    for (i = 0; i < n; i++) Finish[i] = 0;
    for (j = 0; j < m; j++) Work[j] = Available[j];

    int count = 0;
    while (count < n) {
        int found = 0;
        for (i = 0; i < n; i++) {
            if (Finish[i] == 0) {
                int flag = 1;
                for (j = 0; j < m; j++) {
                    if (Need[i][j] > Work[j]) {
                        flag = 0;
                        break;
                    }
                }
                if (flag == 1) {
                    for (k = 0; k < m; k++) {
                        Work[k] += Allocation[i][k];
                    }
                    SafeSequence[count++] = i;
                    Finish[i] = 1;
                    found = 1;
                }
            }
        }
        if (found == 0) {
            printf("\nSystem is in an UNSAFE STATE (Potential Deadlock).\n");
            return 0;
        }
    }

    printf("\nSystem is in a SAFE STATE.\nSafe Sequence: ");
    for (i = 0; i < n; i++) {
        printf("P%d ", SafeSequence[i]);
    }
    printf("\n");

    // --- Resource Request Simulation ---
    int reqProcess;
    printf("\nEnter process number making request (0-%d): ", n-1);
    scanf("%d", &reqProcess);

    int Request[m];
    printf("Enter request vector for process P%d:\n", reqProcess);
    for (j = 0; j < m; j++) {
        scanf("%d", &Request[j]);
    }

    // Step 1: Check if request <= Need
    for (j = 0; j < m; j++) {
        if (Request[j] > Need[reqProcess][j]) {
            printf("Error: Process has exceeded its maximum claim.\n");
            return 0;
        }
    }

    // Step 2: Check if request <= Available
    for (j = 0; j < m; j++) {
        if (Request[j] > Available[j]) {
            printf("Resources not available. Process must wait.\n");
            return 0;
        }
    }

    // Step 3: Pretend to allocate resources
    for (j = 0; j < m; j++) {
        Available[j] -= Request[j];
        Allocation[reqProcess][j] += Request[j];
        Need[reqProcess][j] -= Request[j];
    }

    // Step 4: Check if system remains safe
    for (i = 0; i < n; i++) Finish[i] = 0;
    for (j = 0; j < m; j++) Work[j] = Available[j];
    count = 0;

    while (count < n) {
        int found = 0;
        for (i = 0; i < n; i++) {
            if (Finish[i] == 0) {
                int flag = 1;
                for (j = 0; j < m; j++) {
                    if (Need[i][j] > Work[j]) {
                        flag = 0;
                        break;
                    }
                }
                if (flag == 1) {
                    for (k = 0; k < m; k++) {
                        Work[k] += Allocation[i][k];
                    }
                    SafeSequence[count++] = i;
                    Finish[i] = 1;
                    found = 1;
                }
            }
        }
        if (found == 0) {
            printf("\nRequest cannot be granted. System would be UNSAFE.\n");
            return 0;
        }
    }

    printf("\nRequest can be granted. System remains in SAFE STATE.\nSafe Sequence: ");
    for (i = 0; i < n; i++) {
        printf("P%d ", SafeSequence[i]);
    }
    printf("\n");

    return 0;
}
