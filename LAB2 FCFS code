#include <stdio.h>

int main() {
    int n;
    
    printf("Enter number of processes: ");
    if (scanf("%d", &n) != 1) return 1;
    
    int at[n], bt[n], ct[n], tat[n], wt[n];
    float total_tat = 0, total_wt = 0;
    
    printf("Enter Arrival Time and Burst Time:\n");
    for (int i = 0; i < n; i++) {
        printf("P%d AT BT: ", i + 1);
        if (scanf("%d %d", &at[i], &bt[i]) != 2) return 1;
    }
    
    
    for (int i = 0; i < n; i++) {
        if (i == 0) {
            ct[i] = at[i] + bt[i];
        } else {
            // If the CPU is idle waiting for a process to arrive
            if (at[i] > ct[i - 1]) {
                ct[i] = at[i] + bt[i];
            } else {
                ct[i] = ct[i - 1] + bt[i];
            }
        }
        
        
        tat[i] = ct[i] - at[i];
        total_tat += tat[i];
        
        
        wt[i] = tat[i] - bt[i];
        total_wt += wt[i];
    }
    
    
    printf("\n%-7s %-4s %-4s %-4s %-4s %-4s\n", "Process", "AT", "BT", "CT", "TAT", "WT");
    for (int i = 0; i < n; i++) {
        printf("P%-6d %-4d %-4d %-4d %-4d %-4d\n", i + 1, at[i], bt[i], ct[i], tat[i], wt[i]);
    }
    
    
    printf("\nAverage Turnaround Time: %.2f\n", total_tat / n);
    printf("Average Waiting Time: %.2f\n", total_wt / n);
    
    return 0;
}
