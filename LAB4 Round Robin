#include <stdio.h>

int main() {
    int n, tq;
    int at[20], bt[20], rt[20];
    int ct[20], tat[20], wt[20];
    int queue[100], front = 0, rear = 0;
    int visited[20] = {0};
    int time = 0, completed = 0;

    int gantt_p[100], gantt_t[100];
    int g = 0;

    float avg_wt = 0, avg_tat = 0;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    printf("Enter Arrival Time:\n");
    for(int i=0;i<n;i++){
        printf("P%d: ",i+1);
        scanf("%d",&at[i]);
    }

    printf("Enter Burst Time:\n");
    for(int i=0;i<n;i++){
        printf("P%d: ",i+1);
        scanf("%d",&bt[i]);
        rt[i] = bt[i];
    }

    printf("Enter Time Quantum: ");
    scanf("%d",&tq);

    queue[rear++] = 0;
    visited[0] = 1;

    gantt_t[g] = time;

    while(completed < n){

        int i = queue[front++];

        gantt_p[g++] = i;

        if(rt[i] > tq){
            time += tq;
            rt[i] -= tq;
        }
        else{
            time += rt[i];
            rt[i] = 0;
            ct[i] = time;
            completed++;
        }

        gantt_t[g] = time;

        for(int j=0;j<n;j++){
            if(at[j] <= time && visited[j]==0){
                queue[rear++] = j;
                visited[j] = 1;
            }
        }

        if(rt[i] > 0)
            queue[rear++] = i;
    }

    printf("\nGantt Chart:\n");

    for(int i=0;i<g;i++)
        printf("| P%d ", gantt_p[i]+1);

    printf("|\n");

    for(int i=0;i<=g;i++)
        printf("%d   ", gantt_t[i]);

    printf("\n");

    printf("\nProcess\tAT\tBT\tCT\tTAT\tWT\n");

    for(int i=0;i<n;i++){
        tat[i] = ct[i] - at[i];
        wt[i] = tat[i] - bt[i];

        avg_wt += wt[i];
        avg_tat += tat[i];

        printf("P%d\t%d\t%d\t%d\t%d\t%d\n",
        i+1, at[i], bt[i], ct[i], tat[i], wt[i]);
    }

    printf("\nAverage Waiting Time = %.2f", avg_wt/n);
    printf("\nAverage Turnaround Time = %.2f\n", avg_tat/n);

    return 0;
}
