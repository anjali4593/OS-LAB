#include <stdio.h>

int main() {
    int n;
    printf("Enter number of processes: ");
    scanf("%d", &n);

    int at[20], bt[20], pr[20], ct[20], tat[20], wt[20], rt[20], done[20];
    int gantt_proc[200], gantt_start[200], gantt_end[200];
    int gc_len;

    for (int i = 0; i < n; i++) {
        printf("Enter AT, BT, Priority for P%d: ", i+1);
        scanf("%d %d %d", &at[i], &bt[i], &pr[i]);
        rt[i] = bt[i];
        done[i] = 0;
    }

    
    int time = 0, completed = 0;
    gc_len = 0;
    while (completed < n) {
        int idx = -1, highest = 9999;
        for (int i = 0; i < n; i++) {
            if (!done[i] && at[i] <= time) {
                if (pr[i] < highest) {
                    highest = pr[i];
                    idx = i;
                }
            }
        }
        if (idx == -1) { time++; continue; }
        gantt_proc[gc_len] = idx;
        gantt_start[gc_len] = time;
        time += bt[idx];
        gantt_end[gc_len] = time;
        gc_len++;
        ct[idx] = time;
        tat[idx] = ct[idx] - at[idx];
        wt[idx] = tat[idx] - bt[idx];
        done[idx] = 1;
        completed++;
    }

    printf("\n--- Non-Preemptive Priority Scheduling ---\n");
    printf("PID\tAT\tBT\tPR\tCT\tTAT\tWT\n");
    float total_tat = 0, total_wt = 0;
    for (int i = 0; i < n; i++) {
        printf("P%d\t%d\t%d\t%d\t%d\t%d\t%d\n", i+1, at[i], bt[i], pr[i], ct[i], tat[i], wt[i]);
        total_tat += tat[i];
        total_wt += wt[i];
    }
    printf("\nAverage Turnaround Time = %.2f\n", total_tat/n);
    printf("Average Waiting Time    = %.2f\n", total_wt/n);

    printf("\n--- Gantt Chart (Non-Preemptive) ---\n");
    for (int i = 0; i < gc_len; i++) {
        printf("| P%d (%d-%d) ", gantt_proc[i]+1, gantt_start[i], gantt_end[i]);
    }
    printf("|\n");

    
    for (int i = 0; i < n; i++) {
        rt[i] = bt[i];
        done[i] = 0;
    }
    time = 0; completed = 0; gc_len = 0;
    while (completed < n) {
        int idx = -1, highest = 9999;
        for (int i = 0; i < n; i++) {
            if (!done[i] && at[i] <= time) {
                if (pr[i] < highest) {
                    highest = pr[i];
                    idx = i;
                }
            }
        }
        if (idx == -1) { time++; continue; }
        int start = time;
        while (1) {
            rt[idx]--;
            time++;
            if (rt[idx] == 0) {
                ct[idx] = time;
                tat[idx] = ct[idx] - at[idx];
                wt[idx] = tat[idx] - bt[idx];
                done[idx] = 1;
                completed++;
                break;
            }
            
            int new_idx = -1, new_highest = 9999;
            for (int i = 0; i < n; i++) {
                if (!done[i] && at[i] <= time) {
                    if (pr[i] < new_highest) {
                        new_highest = pr[i];
                        new_idx = i;
                    }
                }
            }
            if (new_idx != idx && new_idx != -1) {
                break; // preempt
            }
        }
        gantt_proc[gc_len] = idx;
        gantt_start[gc_len] = start;
        gantt_end[gc_len] = time;
        gc_len++;
    }

    printf("\n--- Preemptive Priority Scheduling ---\n");
    printf("PID\tAT\tBT\tPR\tCT\tTAT\tWT\n");
    total_tat = 0; total_wt = 0;
    for (int i = 0; i < n; i++) {
        printf("P%d\t%d\t%d\t%d\t%d\t%d\t%d\n", i+1, at[i], bt[i], pr[i], ct[i], tat[i], wt[i]);
        total_tat += tat[i];
        total_wt += wt[i];
    }
    printf("\nAverage Turnaround Time = %.2f\n", total_tat/n);
    printf("Average Waiting Time    = %.2f\n", total_wt/n);

    printf("\n--- Gantt Chart (Preemptive) ---\n");
    for (int i = 0; i < gc_len; i++) {
        printf("| P%d (%d-%d) ", gantt_proc[i]+1, gantt_start[i], gantt_end[i]);
    }
    printf("|\n");

    return 0;
}
