#include <stdio.h>
#include <stdlib.h>
#include <pthread.h>
#include <semaphore.h>
#include <unistd.h>

#define N 5  // Number of philosophers

sem_t chopstick[N];   // Chopstick semaphores
sem_t room;           // Limits number of philosophers in room

void *philosopher(void *num) {
    int i = *(int *)num;

    while (1) {
        printf("Philosopher %d is thinking.\n", i);
        sleep(1);

        sem_wait(&room);
        sem_wait(&chopstick[i]);
        printf("Philosopher %d picked up left chopstick %d.\n", i, i);

        sem_wait(&chopstick[(i+1)%N]);
        printf("Philosopher %d picked up right chopstick %d.\n", i, (i+1)%N);

        printf("Philosopher %d is eating.\n", i);
        sleep(2);

        sem_post(&chopstick[i]);
        sem_post(&chopstick[(i+1)%N]);
        printf("Philosopher %d put down chopsticks %d and %d.\n", i, i, (i+1)%N);

        sem_post(&room);
    }
}

int main() {
    pthread_t tid[N];
    int ids[N];


    for (int i = 0; i < N; i++) {
        sem_init(&chopstick[i], 0, 1);
    }
    sem_init(&room, 0, 4);


    for (int i = 0; i < N; i++) {
        ids[i] = i;
        pthread_create(&tid[i], NULL, philosopher, &ids[i]);
    }


    for (int i = 0; i < N; i++) {
        pthread_join(tid[i], NULL);
    }


    for (int i = 0; i < N; i++) {
        sem_destroy(&chopstick[i]);
    }
    sem_destroy(&room);

    return 0;
}
